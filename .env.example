# Mirsa — Environment Variables
# Copy this file to .env.local and fill in your values

# Demo mode — bypasses all auth checks for the demo routes
DEMO_MODE=true

# Your Vercel deployment URL e.g. https://mirsa.vercel.app
# Leave empty in local development
NEXT_PUBLIC_APP_URL=

# Supabase — project URL and keys from supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude) — used for the classifier route only
ANTHROPIC_API_KEY=sk-ant-your-key

# Groq — used for AI coach chat and weekly summaries
GROQ_API_KEY=your-groq-key

# Demo IDs — filled in after running the seed script (scripts/seed.ts)
# Server-side
DEMO_PATIENT_ID=
DEMO_CAREGIVER_ID=
DEMO_SECONDARY_CAREGIVER_ID=

# Client-side (same values as above, exposed to browser for demo mode)
NEXT_PUBLIC_DEMO_PATIENT_ID=
NEXT_PUBLIC_DEMO_CAREGIVER_ID=
NEXT_PUBLIC_DEMO_SECONDARY_CAREGIVER_ID=
